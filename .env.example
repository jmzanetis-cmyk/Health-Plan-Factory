# ============================================================
# Health Plan Factory — Environment Variables
# ============================================================
# Copy this file to .env.local for local development.
# All variables listed here must be added to Netlify's
# "Environment variables" dashboard before deploying.
# NEVER commit real secrets to the repository.
# ============================================================

# ── Database (Supabase Postgres) ─────────────────────────────
# Use the "Session pooler" connection string from your Supabase
# project → Settings → Database → Connection string.
# Format: postgres://postgres.xxxx:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres
DATABASE_URL=postgres://postgres.YOURPROJECT:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# Supabase project URL and public anon key (for client-side usage)
VITE_SUPABASE_URL=https://YOURPROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGci...

# ── Authentication ────────────────────────────────────────────
# Replit OIDC — required for the default login flow.
# REPL_ID is used by openid-client for discovery; set it in Netlify env vars.
# Find it in your Replit project settings (the UUID after "replit.com/@").
REPL_ID=your-replit-app-uuid
ISSUER_URL=https://replit.com/oidc

# Session secret — generate with: openssl rand -hex 32
SESSION_SECRET=replace_with_a_random_64_char_hex_string

# GitHub OAuth App credentials
# Create at: https://github.com/settings/developers → OAuth Apps
# Callback URL: https://www.healthplanfactory.com/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Stripe ───────────────────────────────────────────────────
# Use test keys (sk_test_...) for staging; live keys for production.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Anthropic AI ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Google Maps ──────────────────────────────────────────────
# Restrict this key to your production domain in Google Cloud Console.
VITE_GOOGLE_MAPS_API_KEY=AIza...

# ── App URLs ─────────────────────────────────────────────────
# Used for OAuth redirect URIs and CORS configuration.
APP_URL=https://www.healthplanfactory.com
