modules = ["nodejs-24", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["github:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
EXPO_PUBLIC_REVENUECAT_TEST_API_KEY = "test_AVMKGAambUWzYSiZMdBPJfVPFis"
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY = "REPLACE_WITH_IOS_KEY"
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY = "REPLACE_WITH_ANDROID_KEY"
