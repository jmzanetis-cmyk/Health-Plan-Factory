# ─────────────────────────────────────────────────────────────────────────────
# Health Plan Factory Mobile — Environment Variables
# Copy this file to .env.local for local development; set secrets in EAS Secrets
# for preview and production builds (https://docs.expo.dev/build-reference/variables/).
# ─────────────────────────────────────────────────────────────────────────────

# ── API server ──────────────────────────────────────────────────────────────
# Production / preview: URL of the deployed API server (no trailing slash).
# Set this in EAS Secrets or in your eas.json build env block.
# In Replit dev the EXPO_PUBLIC_DOMAIN env var is set automatically.
EXPO_PUBLIC_API_URL=https://api.healthplanfactory.com

# ── Authentication ───────────────────────────────────────────────────────────
# Replit OIDC issuer (default is https://replit.com/oidc — change if self-hosted).
EXPO_PUBLIC_ISSUER_URL=https://replit.com/oidc

# Replit Repl ID used as the OIDC client_id.
EXPO_PUBLIC_REPL_ID=your-repl-id-here

# ── RevenueCat ───────────────────────────────────────────────────────────────
# Public API key from the RevenueCat dashboard (Apps → API Keys → Public).
# Required for in-app purchase support on iOS.
EXPO_PUBLIC_REVENUECAT_API_KEY=appl_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EXPO_PUBLIC_REVENUECAT_APPLE_KEY=appl_xxxx

# ── Sentry (Task #84) ────────────────────────────────────────────────────────
# DSN from Sentry project settings (Settings → Client Keys).
# Required for remote crash reporting.
EXPO_PUBLIC_SENTRY_DSN=https://xxxxxxxx@oxxxxxxx.ingest.sentry.io/xxxxxxx
