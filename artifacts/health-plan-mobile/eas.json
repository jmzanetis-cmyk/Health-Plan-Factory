{
  "$schema": "https://raw.githubusercontent.com/expo/eas-cli/main/packages/eas-cli/schema.json",
  "cli": {
    "version": ">= 10.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.healthplanfactory.com"
      }
    },
    "production": {
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.healthplanfactory.com"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "jm.zanetis@gmail.com",
        "ascAppId": "6770102215",
        "appleTeamId": "VNCVGPP9LS"
      }
    }
  }
}
